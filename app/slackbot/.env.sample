# Copy to `.env` for local development: cp .env.sample .env
#
# Slack credentials (from your Slack app config). Outbound calls to Slack are
# real, so use a test workspace/app if you don't want live messages posted.
VERIFICATION_TOKEN=ADD_ME
BOT_TOKEN=ADD_ME
CHANNEL_ID=ADD_ME

# Local stack config
STAGE=dev
WORKOUTS_DB_TABLE=dev-workouts-table
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=localhost
PORT=3000
